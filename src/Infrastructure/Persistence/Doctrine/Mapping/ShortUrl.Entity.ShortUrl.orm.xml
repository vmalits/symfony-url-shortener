<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Domain\ShortUrl\Entity\ShortUrl" table="short_urls">
        <unique-constraints>
            <unique-constraint name="UNIQ_CODE" columns="code"/>
        </unique-constraints>

        <id name="id" type="integer" column="id">
            <generator strategy="IDENTITY"/>
        </id>

        <field name="originalUrl" type="string" column="original_url" length="2048"/>
        <field name="code" type="string" column="code" length="10"/>
        <field name="createdAt" type="datetime_immutable" column="created_at"/>

        <many-to-one field="user" target-entity="App\Domain\User\Entity\User">
            <join-column name="user_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>

        <one-to-many field="clicks" target-entity="App\Domain\Click\Entity\Click" mapped-by="shortUrl" orphan-removal="true">
            <cascade>
                <cascade-persist/>
            </cascade>
        </one-to-many>
    </entity>

</doctrine-mapping>
