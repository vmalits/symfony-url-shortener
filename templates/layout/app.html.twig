<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Dashboard{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {{ importmap('app') }}
    <style>
        .custom-scroll::-webkit-scrollbar {
            width: 8px;
        }
        .custom-scroll::-webkit-scrollbar-track {
            background: transparent;
        }
        .custom-scroll::-webkit-scrollbar-thumb {
            background: #e2e8f0;
            border-radius: 100px;
        }
        .custom-scroll::-webkit-scrollbar-thumb:hover {
            background: #cbd5e1;
        }
        .custom-scroll {
            scrollbar-width: thin;
            scrollbar-color: #e2e8f0 transparent;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 font-sans antialiased overflow-hidden">

<div class="flex h-screen">

    <aside class="w-72 bg-white border-r border-slate-200 hidden md:flex flex-col flex-shrink-0">
        <div class="p-8 pb-10">
            <a href="/" class="flex items-center space-x-2">
                <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center text-white font-bold text-lg">S</div>
                <span class="font-bold text-xl tracking-tight uppercase">Shorten</span>
            </a>
        </div>

        <nav class="flex-1 px-6 space-y-1">
            {% set current_route = app.request.attributes.get('_route') %}
            <a href="{{ path('app_dashboard') }}" class="group flex items-center px-4 py-3 text-sm font-medium rounded-xl {{ current_route == 'app_dashboard' ? 'bg-slate-100 text-indigo-700' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900' }} transition-all">
                <svg class="mr-3 h-5 w-5 {{ current_route == 'app_dashboard' ? 'text-indigo-500' : 'text-slate-400 group-hover:text-slate-500' }}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                </svg>
                Dashboard
            </a>
            <a href="{{ path('app_links') }}" class="group flex items-center px-4 py-3 text-sm font-medium rounded-xl {{ current_route == 'app_links' ? 'bg-slate-100 text-indigo-700' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900' }} transition-all">
                <svg class="mr-3 h-5 w-5 {{ current_route == 'app_links' ? 'text-indigo-500' : 'text-slate-400 group-hover:text-slate-500' }}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13.5V15a2 2 0 01-2 2H5" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 9h1a2 2 0 012 2v1.5M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.102 1.101" />
                </svg>
                My Links
            </a>
        </nav>

        <div class="p-6 border-t border-slate-100">
            <div class="bg-indigo-50 rounded-2xl p-4">
                <p class="text-xs font-semibold text-indigo-700 uppercase tracking-wider mb-1">Current User</p>
                <p class="text-sm text-slate-900 font-medium truncate">{{ app.user.email ?? 'Guest' }}</p>
            </div>
        </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0 overflow-hidden">

        <header class="h-20 flex items-center justify-between px-10 flex-shrink-0 bg-slate-50/80 backdrop-blur-sm border-b border-slate-100">
            <h1 class="text-2xl font-bold tracking-tight text-slate-900">
                {% block header_title %}Dashboard{% endblock %}
            </h1>

            <div class="flex items-center space-x-6">
                {% if app.user %}
                    <a href="/logout" class="text-sm font-semibold text-slate-500 hover:text-red-600 transition-colors">Logout</a>
                {% else %}
                    <a href="/login" class="text-sm font-semibold text-indigo-600 hover:text-indigo-700 transition-colors">Sign In</a>
                {% endif %}
            </div>
        </header>

        <main class="flex-1 overflow-y-auto custom-scroll">
            <div class="p-10 pt-6">
                <div class="max-w-6xl mx-auto">
                    {% block body %}{% endblock %}
                </div>
            </div>
        </main>

    </div>

</div>

<script type="module">import 'app';</script>
</body>
</html>
