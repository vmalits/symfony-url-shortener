<div {{ attributes }}>
    <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-slate-900">Click Analytics</h3>
            <div class="flex gap-3">
                <button
                    data-action="live#update"
                    data-model="days"
                    data-value="7"
                    class="px-6 py-3 text-sm font-medium whitespace-nowrap rounded-xl transition {{ days == 7 ? 'bg-indigo-600 text-white shadow-md shadow-indigo-200' : 'bg-slate-100 text-slate-600 hover:bg-slate-200' }}"
                >
                    7 days
                </button>
                <button
                    data-action="live#update"
                    data-model="days"
                    data-value="30"
                    class="px-6 py-3 text-sm font-medium whitespace-nowrap rounded-xl transition {{ days == 30 ? 'bg-indigo-600 text-white shadow-md shadow-indigo-200' : 'bg-slate-100 text-slate-600 hover:bg-slate-200' }}"
                >
                    30 days
                </button>
            </div>
        </div>
        <div class="h-64">
            {{ render_chart(this.chart) }}
        </div>
    </div>
</div>
