{% extends 'layout/app.html.twig' %}

{% block header_title %}Overview{% endblock %}

{% block body %}
    <div class="mb-8">
        <h2 class="text-3xl font-extrabold text-slate-900 mb-2">Dashboard</h2>
        <p class="text-slate-500 text-lg">Your link analytics at a glance.</p>
    </div>

    {% set totalClicks = 0 %}
    {% for id, count in clickCounts %}
        {% set totalClicks = totalClicks + count %}
    {% endfor %}
    {% set totalLinks = shortUrls|length %}

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-slate-500">Total Links</p>
                    <p class="text-2xl font-bold text-slate-900">{{ totalLinks }}</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-slate-500">Total Clicks</p>
                    <p class="text-2xl font-bold text-slate-900">{{ totalClicks }}</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
            <div class="flex items-center space-x-4">
                <div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center text-purple-600">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm text-slate-500">Avg per Link</p>
                    <p class="text-2xl font-bold text-slate-900">{{ totalLinks > 0 ? (totalClicks / totalLinks)|round(1) : '0' }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Click Analytics Chart -->
    {{ component('click_chart') }}

    <!-- Analytics Grid -->
    {% if countries|length > 0 or referrers|length > 0 or devices|length > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-8">
            <!-- Top Countries -->
            <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
                <div class="flex items-center space-x-3 mb-5">
                    <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900">Top Countries</h3>
                </div>
                {% if countries|length > 0 %}
                    <ul class="space-y-3">
                        {% for row in countries %}
                            <li class="flex items-center justify-between">
                                <div class="flex items-center space-x-3">
                                    <span class="text-xl">{{ row.country ? country_flag(row.country) : '&#127757;' }}</span>
                                    <span class="text-sm font-medium text-slate-700">{{ row.country ?? 'Unknown' }}</span>
                                </div>
                                <span class="text-sm font-bold text-slate-900 bg-slate-50 px-3 py-1 rounded-lg">{{ row.cnt }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-sm text-slate-400">No data yet</p>
                {% endif %}
            </div>

            <!-- Top Referrers -->
            <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
                <div class="flex items-center space-x-3 mb-5">
                    <div class="w-10 h-10 bg-purple-50 rounded-xl flex items-center justify-center text-purple-600">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.102 1.101" />
                        </svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900">Top Referrers</h3>
                </div>
                {% if referrers|length > 0 %}
                    <ul class="space-y-3">
                        {% for row in referrers %}
                            <li class="flex items-center justify-between">
                                <span class="text-sm font-medium text-slate-700 truncate max-w-[180px]" title="{{ row.referrer ?? 'Direct' }}">{{ row.referrer ? row.referrer|replace({'https://': '', 'http://': '', 'www.': ''})|trim('/') : 'Direct' }}</span>
                                <span class="text-sm font-bold text-slate-900 bg-slate-50 px-3 py-1 rounded-lg flex-shrink-0">{{ row.cnt }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-sm text-slate-400">No data yet</p>
                {% endif %}
            </div>

            <!-- Devices -->
            <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm">
                <div class="flex items-center space-x-3 mb-5">
                    <div class="w-10 h-10 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="text-base font-bold text-slate-900">Devices</h3>
                </div>
                {% if devices|length > 0 %}
                    <ul class="space-y-3">
                        {% for row in devices %}
                            <li class="flex items-center justify-between">
                                <div class="flex items-center space-x-3">
                                    <span class="text-lg">
                                        {% if row.device == 'Mobile' %}&#128241;{% elseif row.device == 'Tablet' %}&#128241;{% elseif row.device == 'Desktop' %}&#128187;{% else %}&#10067;{% endif %}
                                    </span>
                                    <span class="text-sm font-medium text-slate-700">{{ row.device }}</span>
                                </div>
                                <span class="text-sm font-bold text-slate-900 bg-slate-50 px-3 py-1 rounded-lg">{{ row.cnt }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-sm text-slate-400">No data yet</p>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endblock %}
