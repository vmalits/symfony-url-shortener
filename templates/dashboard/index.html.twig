                        </svg>
                    </div>
                    <div>
                        <p class="text-slate-900 font-bold text-lg mb-1 group-hover:text-indigo-600 transition-colors">shrt.ly/xK9f2z</p>
                        <p class="text-slate-400 text-sm truncate max-w-xs md:max-w-md">https://github.com/symfony/symfony-url-shortener-example</p>
                    </div>
                </div>

                <div class="mt-4 md:mt-0 flex items-center space-x-4">
                    <div class="px-4 py-2 bg-slate-50 rounded-lg text-slate-600 font-bold text-sm">
                        <span class="text-slate-900 mr-1">1,248</span> clicks
                    </div>
                    <button class="p-3 bg-slate-50 hover:bg-indigo-50 text-slate-400 hover:text-indigo-600 rounded-xl transition-all" title="Copy Link">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                        </svg>
