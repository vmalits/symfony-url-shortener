{% extends 'layout/app.html.twig' %}

{% block header_title %}Overview{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <div class="mb-12">
        <h2 class="text-3xl font-extrabold text-slate-900 mb-2">Shorten your links.</h2>
        <p class="text-slate-500 text-lg">Instant URL shortening with advanced analytics.</p>
    </div>

    <!-- Flash Messages -->
    {% for flash in app.flashes('success') %}
        <div class="bg-green-50 border border-green-200 rounded-2xl p-6 mb-8 flex items-center space-x-4">
            <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-green-600 flex-shrink-0">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <p class="text-green-800 font-medium">{{ flash }}</p>
        </div>
    {% endfor %}

    {% for flash in app.flashes('error') %}
        <div class="bg-red-50 border border-red-200 rounded-2xl p-6 mb-8 flex items-center space-x-4">
            <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center text-red-600 flex-shrink-0">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </div>
            <p class="text-red-800 font-medium">{{ flash }}</p>
        </div>
    {% endfor %}

    <!-- URL Input Box -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-100 p-8 mb-12 transform transition-all hover:shadow-md">
        <form action="{{ path('app_links_create') }}" method="POST" class="flex flex-col md:flex-row gap-4">
            <input type="hidden" name="_token" value="{{ csrf_token('create_link') }}">
            <div class="flex-1 relative group">
                <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none transition-colors group-focus-within:text-indigo-600 text-slate-400">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13.5V15a2 2 0 01-2 2H5" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 9h1a2 2 0 012 2v1.5M10.172 13.828a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.102 1.101" />
                    </svg>
                </div>
                <input type="url" required name="originalUrl" placeholder="https://very-long-url.com/something-really-long-here"
                       class="w-full bg-slate-50 border-transparent rounded-2xl py-5 pl-16 pr-6 text-lg text-slate-900 placeholder-slate-400 focus:bg-white focus:border-indigo-500 focus:ring-4 focus:ring-indigo-100 transition-all outline-none">
            </div>
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-10 py-5 rounded-2xl shadow-lg shadow-indigo-100 transition-all active:scale-95">
                Shorten Now
            </button>
        </form>
    </div>

    <!-- Recent Links Section -->
    <div class="space-y-6">
        <div class="flex items-center justify-between">
            <h3 class="text-xl font-bold text-slate-900 tracking-tight">Recent Links</h3>
            {% if shortUrls|length > 0 %}
                <span class="text-sm text-slate-500">{{ shortUrls|length }} link{{ shortUrls|length > 1 ? 's' : '' }}</span>
            {% endif %}
        </div>

        {% if shortUrls|length > 0 %}
            <div class="grid grid-cols-1 gap-4">
                {% for shortUrl in shortUrls %}
                    <div class="bg-white p-6 rounded-2xl border border-slate-100 flex flex-col md:flex-row md:items-center justify-between group hover:border-indigo-200 transition-all shadow-sm hover:shadow-md">
                        <div class="flex items-center space-x-6">
                            <div class="w-12 h-12 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600 group-hover:bg-indigo-600 group-hover:text-white transition-all">
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                                </svg>
                            </div>
                            <div>
                                <a href="{{ url('app_redirect', {code: shortUrl.code}) }}" target="_blank" class="text-slate-900 font-bold text-lg mb-1 group-hover:text-indigo-600 transition-colors hover:underline">
                                    {{ url('app_redirect', {code: shortUrl.code}) }}
                                </a>
                                <p class="text-slate-400 text-sm truncate max-w-xs md:max-w-md">{{ shortUrl.originalUrl }}</p>
                            </div>
                        </div>

                        <div class="mt-4 md:mt-0 flex items-center space-x-4">
                            <div class="px-4 py-2 bg-slate-50 rounded-xl text-slate-600 font-semibold text-sm">
                                <span class="text-slate-900">{{ clickCounts[shortUrl.id] ?? 0 }}</span> clicks
                            </div>
                            <button onclick="navigator.clipboard.writeText('{{ url('app_redirect', {code: shortUrl.code}) }}').then(() => this.innerHTML='Copied!').then(() => setTimeout(() => this.innerHTML='<svg class=\\'h-5 w-5\\' fill=\\'none\\' viewBox=\\'0 0 24 24\\' stroke=\\'currentColor\\'><path stroke-linecap=\\'round\\' stroke-linejoin=\\'round\\' stroke-width=\\'2\\' d=\\'M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3\\' /></svg>', 2000))" class="p-3 bg-slate-50 hover:bg-indigo-50 text-slate-400 hover:text-indigo-600 rounded-xl transition-all" title="Copy Link">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                                </svg>
                            </button>
                            <form action="{{ path('app_links_delete', {id: shortUrl.id}) }}" method="POST" class="inline" onsubmit="return confirm('Delete this link?')">
                                <input type="hidden" name="_method" value="DELETE">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_link_' ~ shortUrl.id) }}">
                                <button type="submit" class="p-3 bg-slate-50 hover:bg-red-50 text-slate-400 hover:text-red-600 rounded-xl transition-all" title="Delete">
                                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="bg-white p-12 rounded-2xl border border-slate-100 text-center">
                <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4 text-slate-400">
                    <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                    </svg>
                </div>
                <p class="text-slate-500 text-lg">No links yet. Create your first short link above!</p>
            </div>
        {% endif %}
    </div>
{% endblock %}
